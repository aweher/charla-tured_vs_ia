# ============================================================
# Tu Red vs. La IA — variables de entorno del stack
# ------------------------------------------------------------
# Copiá este archivo a .env y completá los valores.
# NUNCA commitees el .env real al repo.
# ============================================================

# --- Profiles (qué capas levanta docker compose up -d) ------
# Dejá todos para levantar el stack completo.
# Para levantar solo una capa, dejá únicamente su nombre.
# Ejemplo solo capa 1+2: COMPOSE_PROFILES=capa1,capa2
# COMPOSE_PROFILES=capa1,capa2,capa3,capa4,capa5,siem,llm
COMPOSE_PROFILES=capa1

# --- Identidad del operador ---------------------------------
ASN=AS65007                     # Tu ASN (usá AS65007 para pruebas con rangos de doc)
PREFIX_V4=198.18.0.0/15         # Tu prefijo IPv4 principal
PREFIX_V6=2001:db8::/32         # Tu prefijo IPv6 principal
ORG_NAME=AyudaLA-Demo           # Nombre corto sin espacios para configs
CONTACT_EMAIL=admin@example.com # Email de contacto técnico

# --- Routinator (RPKI) --------------------------------------
ROUTINATOR_HTTP_PORT=9556
ROUTINATOR_RTR_PORT=3323

# --- pmacct (NetFlow/sFlow) ---------------------------------
PMACCT_NFLOW_PORT=2055
PMACCT_SFLOW_PORT=6343

# --- Akvorado (visualización flows) -------------------------
AKVORADO_HTTP_PORT=8081

# --- CrowdSec ------------------------------------------------
CROWDSEC_API_PORT=8080
CROWDSEC_LAPI_KEY=changeme-generate-with-openssl-rand-hex-32
CROWDSEC_ENROLL_KEY=optional-from-app.crowdsec.net

# --- Suricata ------------------------------------------------
SURICATA_INTERFACE=eth0         # Interfaz de captura (cambiar por la real)

# --- Wazuh ---------------------------------------------------
WAZUH_DASHBOARD_PORT=5601
WAZUH_INDEXER_PORT=9200
WAZUH_API_PORT=55000
WAZUH_INDEXER_PASSWORD=Changeme-WazuhIndexer-2026!
WAZUH_API_PASSWORD=Changeme-WazuhAPI-2026!

# --- fastnetmon ----------------------------------------------
FASTNETMON_API_PORT=10007
FASTNETMON_RTBH_COMMUNITY=65007:666   # Community para anuncio RTBH

# --- MISP ----------------------------------------------------
MISP_HTTP_PORT=8083
MISP_BASEURL=http://localhost:8083
MISP_ADMIN_EMAIL=admin@example.com
MISP_ADMIN_PASSWORD=Changeme-MISP-2026!

# --- n8n -----------------------------------------------------
N8N_HTTP_PORT=5678
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=Changeme-N8N-2026!

# --- Ollama (LLM local) -------------------------------------
OLLAMA_PORT=11434
OLLAMA_MODELS_VOLUME=./ollama/models

# --- Open WebUI (interfaz Ollama) ---------------------------
OPENWEBUI_PORT=3000
OPENWEBUI_SECRET_KEY=changeme-generate-with-openssl-rand-hex-32

# --- Grafana (visualización) --------------------------------
GRAFANA_PORT=3001
GRAFANA_ADMIN_PASSWORD=Changeme-Grafana-2026!

# --- Dashboard PPT (guía de servicios) -----------------------
DASHBOARD_PPT_PORT=32000
